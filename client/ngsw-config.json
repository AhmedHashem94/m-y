{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/icons/**",
          "/**/*.svg",
          "/**/*.png"
        ],
        "urls": [
          "https://fonts.googleapis.com/**",
          "https://fonts.gstatic.com/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-products",
      "urls": ["/api/products", "/api/products/**"],
      "cacheConfig": {
        "maxSize": 50,
        "maxAge": "1h",
        "timeout": "5s",
        "strategy": "freshness"
      }
    },
    {
      "name": "api-companies",
      "urls": ["/api/companies"],
      "cacheConfig": {
        "maxSize": 20,
        "maxAge": "6h",
        "timeout": "5s",
        "strategy": "freshness"
      }
    },
    {
      "name": "product-images",
      "urls": ["https://rriazbzgajmlznftsxdd.supabase.co/storage/**"],
      "cacheConfig": {
        "maxSize": 100,
        "maxAge": "30d",
        "strategy": "performance"
      }
    },
    {
      "name": "i18n",
      "urls": ["/assets/i18n/**"],
      "cacheConfig": {
        "maxSize": 5,
        "maxAge": "7d",
        "timeout": "3s",
        "strategy": "freshness"
      }
    }
  ],
  "navigationRequestStrategy": "freshness"
}
